# Academic RAG — Environment Configuration
# Copy this file to .env and fill in your values.

# ============================================
# Embedding Provider Configuration
# ============================================

# Provider type: openai | sentence-transformers
EMBEDDING_PROVIDER=openai

# Model name (varies by provider):
#   OpenAI: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
#   Qwen (via aiping.cn): Qwen3-Embedding-8B
#   Local: all-MiniLM-L6-v2, paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_MODEL=text-embedding-3-small

# API endpoint (for OpenAI-compatible providers)
EMBEDDING_API_BASE=https://api.openai.com/v1

# API key (not needed for sentence-transformers)
EMBEDDING_API_KEY=sk-your-api-key-here

# Vector dimension (auto-detected if not set)
# EMBEDDING_DIMENSION=1536

# ============================================
# Project Paths (optional overrides)
# ============================================

# Override the project root directory
# RAG_PROJECT_ROOT=/path/to/your/project
